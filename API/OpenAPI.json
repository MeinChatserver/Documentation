            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "properties": {
                    "type": "object"
                  },
                  "elements": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
