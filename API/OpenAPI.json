        "tags": [
          "System"
        ],
        "summary": "Get logs for specific date",
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "example": "2026-05-23"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Logs for the specified date"
          },
          "400": {
            "description": "Invalid date format"
