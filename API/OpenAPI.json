{
  "openapi": "3.0.0",
  "info": {
    "title": "Mein Chatserver - REST API",
    "version": "2.0.0",
    "description": "Moderne REST API für das Multi-Tenant Chat-System Mein Chatserver. Vollständige Verwaltung von Benutzern, Räumen, Tickets, Authentifizierung und Systemkonfiguration mit Bearer Token Authentication."
  },
  "servers": [
    {
      "url": "https://demo.mein-chatserver.de",
      "description": "Demo Server (ersetze mit deiner Domain)"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/windows": {
      "get": {
        "tags": [
          "Windows"
        ],
        "summary": "List all windows (paginated)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of windows"
          }
        }
      },
      "post": {
        "tags": [
          "Windows"
        ],
        "summary": "Create new window",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "properties": {
                    "type": "object"
                  },
                  "elements": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                },
                "required": [
                  "name",
                  "properties",
                  "elements"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Window created"
          }
        }
      }
    },
    "/window/{id}": {
      "get": {
        "tags": [
