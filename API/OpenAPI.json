                  "password": {
                    "type": "string",
                    "minLength": 8
                  },
                  "permissions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "username",
                  "email",
                  "rank"
