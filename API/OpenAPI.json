                  "content": {
                    "type": "string",
                    "maxLength": 10000
                  }
                },
                "required": [
                  "content"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reply added"
          },
          "409": {
            "description": "Ticket already closed"
          }
        }
      }
    },
    "/ticket/{id}/close": {
