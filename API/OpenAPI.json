    "/tickets": {
      "get": {
        "tags": [
          "Support Tickets"
        ],
        "summary": "List all support tickets (paginated)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of support tickets"
          }
        }
      },
      "post": {
        "tags": [
          "Support Tickets"
        ],
        "summary": "Create new support ticket",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "integer"
                  },
                  "priority": {
                    "type": "string",
                    "enum": [
                      "LOW",
                      "NORMAL",
                      "HIGH"
                    ]
                  },
                  "subject": {
                    "type": "string",
                    "maxLength": 255
                  },
                  "content": {
                    "type": "string",
                    "maxLength": 10000
                  }
                },
                "required": [
                  "category",
                  "priority",
                  "subject",
                  "content"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created"
          }
        }
      }
    },
    "/ticket/{id}": {
      "get": {
        "tags": [
          "Support Tickets"
        ],
        "summary": "Get ticket with replies",
        "parameters": [
          {
            "name": "id",
            "in": "path",
